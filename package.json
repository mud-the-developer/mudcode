{
  "name": "@mudramo/mudcode",
  "version": "1.1.39",
  "description": "Bridge AI agent outputs to Discord via Claude Code hooks and tmux",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mudcode": "bin/mudcode"
  },
  "scripts": {
    "dev": "tsx src/daemon-entry.ts",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "prepare": "node scripts/setup/prepare.mjs",
    "start": "node dist/src/daemon-entry.js",
    "pages:dev": "vite",
    "pages:build": "vite build",
    "pages:preview": "vite preview",
    "setup:claude-plugin": "tsx scripts/setup/setup-claude-plugin.ts",
    "setup:gemini-hook": "tsx scripts/setup/setup-gemini-hook.ts",
    "setup:opencode-plugin": "tsx scripts/setup/setup-opencode-plugin.ts",
    "migration:check": "node scripts/migration/migrate-discode-cleanup.mjs --check",
    "migration:clean": "node scripts/migration/migrate-discode-cleanup.mjs --clean",
    "build:release:binaries": "bun run scripts/release/build-binaries.ts",
    "build:release:binaries:single": "bun run scripts/release/build-binaries.ts --single",
    "build:release:binaries:host": "bun run scripts/release/build-binaries.ts --host-only",
    "build:release:binaries:linux": "bun run scripts/release/build-binaries.ts --profile linux",
    "build:release:manifest": "node scripts/release/rebuild-release-manifest.mjs",
    "build:release:npm": "node scripts/release/build-npm-package.mjs",
    "build:release": "bun run build:release:binaries && bun run build:release:npm",
    "build:release:linux": "bun run build:release:binaries:linux && bun run build:release:npm",
    "pack:release": "node scripts/release/pack-release.mjs",
    "publish:release": "node scripts/release/publish-release.mjs",
    "publish:release:dry-run": "node scripts/release/publish-release.mjs --dry-run",
    "publish:release:single": "node scripts/release/publish-release.mjs --single",
    "publish:release:single:dry-run": "node scripts/release/publish-release.mjs --single --dry-run",
    "publish:release:bun": "node scripts/release/publish-release.mjs --pm bun",
    "publish:release:bun:dry-run": "node scripts/release/publish-release.mjs --pm bun --dry-run",
    "publish:release:bun:single": "node scripts/release/publish-release.mjs --pm bun --single",
    "publish:release:bun:single:dry-run": "node scripts/release/publish-release.mjs --pm bun --single --dry-run",
    "publish:release:bun:linux": "node scripts/release/publish-release.mjs --pm bun --profile linux",
    "publish:release:bun:linux:dry-run": "node scripts/release/publish-release.mjs --pm bun --profile linux --dry-run",
    "version:check": "node scripts/check/check-version-alignment.mjs",
    "todo:check": "node scripts/check/check-todo-fixme.mjs",
    "event-contract:check": "node scripts/check/check-codex-event-contract.mjs",
    "orchestrator:auto:check": "vitest run tests/bridge/runtime/message-router.test.ts tests/index.test.ts",
    "ops:doctor": "bun dist/bin/mudcode.js doctor",
    "ops:doctor:fix": "bun dist/bin/mudcode.js doctor --fix",
    "ops:daemon:restart": "bun dist/bin/mudcode.js daemon restart",
    "ops:self-heal": "bun run build && bun run ops:doctor:fix && bun run ops:daemon:restart",
    "ops:verify:fast": "bun run typecheck && bun run test -- tests/config/index.test.ts tests/bridge/runtime/message-router.test.ts tests/bridge/runtime/capture-poller.test.ts tests/index.test.ts",
    "prompt-refiner:report": "node scripts/prompt/prompt-refiner-shadow-report.mjs",
    "prompt-refiner:export-gepa": "cargo run --manifest-path mudcode-rs/Cargo.toml --bin prompt_refiner_shadow_to_gepa --release --",
    "prompt-refiner:export-gepa:js": "node scripts/prompt/prompt-refiner-shadow-to-gepa.mjs",
    "prompt-refiner:codex": "node scripts/prompt/prompt-refiner-codex-optimize.mjs",
    "prompt-refiner:codex:smoke": "node scripts/prompt/prompt-refiner-codex-optimize.mjs --smoke --fresh --changed-only --iterations 3 --subset-train 24 --subset-val 12 --run-dir .mudcode/codex-opt/run-smoke",
    "prompt-refiner:codex:pipeline": "bun run prompt-refiner:export-gepa -- --val-ratio 0.2 --all && bun run prompt-refiner:codex -- --changed-only --fresh --iterations 4",
    "prompt-refiner:gepa": "uvx --from gepa python scripts/prompt/prompt-refiner-gepa-optimize.py",
    "prompt-refiner:gepa:activate": "uvx --from gepa python scripts/prompt/prompt-refiner-gepa-optimize.py --activate",
    "prompt-refiner:gepa:smoke": "uvx --from gepa python scripts/prompt/prompt-refiner-gepa-optimize.py --smoke --fresh --changed-only --max-metric-calls 24 --subset-train 24 --subset-val 12 --run-dir .mudcode/gepa/run-smoke",
    "prompt-refiner:gepa:pipeline": "bun run prompt-refiner:export-gepa -- --val-ratio 0.2 --all && bun run prompt-refiner:gepa:activate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:tmux": "MUDCODE_E2E_TMUX=1 vitest run tests/tmux/manager.integration.test.ts",
    "test:replay:capture": "vitest run tests/bridge/runtime/capture-poller.replay.test.ts",
    "release:verify:bun": "bun run version:check && bun run typecheck && bun run test && bun run test:e2e:tmux && bun run publish:release:bun:dry-run",
    "release:verify:bun:single": "bun run version:check && bun run typecheck && bun run test && bun run test:e2e:tmux && bun run publish:release:bun:single:dry-run",
    "release:verify:bun:linux": "bun run version:check && bun run typecheck && bun run test && bun run test:e2e:tmux && bun run publish:release:bun:linux:dry-run",
    "release:publish:bun": "bun run release:verify:bun && bun run publish:release:bun -- --skip-build",
    "release:publish:bun:single": "bun run release:verify:bun:single && bun run publish:release:bun:single -- --skip-build",
    "release:publish:bun:linux": "bun run release:verify:bun:linux && bun run publish:release:bun:linux -- --skip-build",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:local": "node scripts/ci/ci-local.mjs",
    "ci:local:e2e": "node scripts/ci/ci-local.mjs --with-e2e"
  },
  "keywords": [
    "discord",
    "ai-agent",
    "claude-code",
    "tmux",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@mudramo/mudcode-darwin-arm64": "1.1.39",
    "@mudramo/mudcode-darwin-x64": "1.1.39",
    "@mudramo/mudcode-darwin-x64-baseline": "1.1.39",
    "@mudramo/mudcode-linux-arm64": "1.1.39",
    "@mudramo/mudcode-linux-arm64-musl": "1.1.39",
    "@mudramo/mudcode-linux-x64": "1.1.39",
    "@mudramo/mudcode-linux-x64-baseline": "1.1.39",
    "@mudramo/mudcode-linux-x64-baseline-musl": "1.1.39",
    "@mudramo/mudcode-linux-x64-musl": "1.1.39",
    "@mudramo/mudcode-windows-x64": "1.1.39",
    "@mudramo/mudcode-windows-x64-baseline": "1.1.39"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@opentui/core": "^0.1.77",
    "@opentui/solid": "^0.1.77",
    "@slack/bolt": "^4.6.0",
    "@types/yargs": "^17.0.35",
    "chalk": "^5.3.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "solid-js": "^1.9.9",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^7.1.5",
    "vitest": "^4.0.18"
  }
}
